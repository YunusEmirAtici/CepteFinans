<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.finanscepte.desktop.controller.DashboardController"
      spacing="16"
      styleClass="dashboard-root">

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label fx:id="welcomeLabel" styleClass="dashboard-title"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Yenile" onAction="#initialize" styleClass="refresh-button"/>
        <Button text="Cikis Yap" onAction="#handleLogout" styleClass="logout-button"/>
    </HBox>

    <HBox spacing="16" alignment="CENTER">
        <VBox styleClass="summary-card income-card" alignment="CENTER">
            <Label text="Toplam Gelir" styleClass="summary-label"/>
            <Label fx:id="totalIncomeLabel" text="0,00 TL" styleClass="summary-value income-text"/>
        </VBox>
        <VBox styleClass="summary-card expense-card" alignment="CENTER">
            <Label text="Toplam Gider" styleClass="summary-label"/>
            <Label fx:id="totalExpenseLabel" text="0,00 TL" styleClass="summary-value expense-text"/>
        </VBox>
        <VBox styleClass="summary-card balance-card" alignment="CENTER">
            <Label text="Net Bakiye" styleClass="summary-label"/>
            <Label fx:id="netBalanceLabel" text="0,00 TL" styleClass="summary-value"/>
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox styleClass="chart-container" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Canvas fx:id="pieChartCanvas" width="520" height="300"/>
        </VBox>
        <VBox styleClass="chart-container" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Canvas fx:id="barChartCanvas" width="620" height="300"/>
        </VBox>
    </HBox>

    <VBox styleClass="alert-container" spacing="6">
        <Label text="Butce Uyarlari" styleClass="alert-title"/>
        <ScrollPane fitToWidth="true" prefHeight="120">
            <VBox fx:id="budgetAlertsBox" spacing="4"/>
        </ScrollPane>
    </VBox>
</VBox>
