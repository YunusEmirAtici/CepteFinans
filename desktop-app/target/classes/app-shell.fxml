<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.finanscepte.desktop.controller.AppShellController"
            styleClass="app-shell-root">
    <left>
        <VBox styleClass="sidebar" spacing="8" prefWidth="220">
            <padding>
                <Insets top="16" right="12" bottom="16" left="12"/>
            </padding>
            <Label text="FinansCepte" styleClass="sidebar-title"/>
            <Label text="Kullanici" styleClass="sidebar-label"/>
            <Label fx:id="userLabel" styleClass="sidebar-user"/>
            <Button fx:id="dashboardNavButton" text="Dashboard" styleClass="sidebar-button" onAction="#showDashboard"/>
            <Button fx:id="transactionsNavButton" text="Islemler" styleClass="sidebar-button" onAction="#showTransactions"/>
            <Button fx:id="budgetsNavButton" text="Butceler" styleClass="sidebar-button" onAction="#showBudgets"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="Cikis Yap" styleClass="logout-button" onAction="#handleLogout"/>
        </VBox>
    </left>
    <center>
        <HBox styleClass="content-wrapper">
            <StackPane fx:id="contentPane" HBox.hgrow="ALWAYS"/>
        </HBox>
    </center>
</BorderPane>
